# Auth - generate with: openssl rand -base64 32
AUTH_SECRET=

# The canonical URL of your deployment (required for NextAuth callbacks in production)
AUTH_URL=http://localhost:3000/api/auth

# WebAuthn - set to your domain for production
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:3000

# Database path (defaults to ./dev-hub.db)
DB_PATH=./dev-hub.db
