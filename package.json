{
  "name": "dev-hub",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "NODE_ENV=production next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "postinstall": "find node_modules -path '*/node-pty/prebuilds/*/spawn-helper' -type f -exec chmod +x {} + 2>/dev/null || true",
    "check": "pnpm format && pnpm lint && pnpm test && pnpm build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && pnpm --filter @devhub/shared typecheck && pnpm --filter @devhub/agent typecheck",
    "agent:dev": "pnpm --filter @devhub/agent dev",
    "agent:start": "pnpm --filter @devhub/agent start",
    "agent:typecheck": "pnpm --filter @devhub/agent typecheck"
  },
  "dependencies": {
    "@devhub/shared": "workspace:*",
    "@monaco-editor/react": "^4.7.0",
    "@opencode-ai/sdk": "^1.2.27",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.91.3",
    "@types/hast": "^3.0.4",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "ansi-to-html": "^0.7.2",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "drizzle-orm": "^0.45.1",
    "fzf": "^0.5.2",
    "gemoji": "^8.1.0",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.575.0",
    "monaco-editor": "^0.55.1",
    "next": "16.1.6",
    "next-auth": "5.0.0-beta.30",
    "node-pty": "^1.1.0",
    "otplib": "^13.4.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "react-virtuoso": "^4.18.3",
    "recharts": "^3.8.0",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "simple-git": "^3.33.0",
    "sonner": "^2.0.7",
    "systeminformation": "^5.31.5",
    "tailwind-merge": "^3.5.0",
    "ws": "^8.19.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.19.37",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.1.6",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "node-pty"
    ]
  }
}
