    "highlight.js": "^11.11.1",
    "lucide-react": "^0.575.0",
    "monaco-editor": "^0.55.1",
    "next": "16.1.6",
    "next-auth": "5.0.0-beta.30",
    "otplib": "^13.3.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "react-virtuoso": "^4.18.3",
