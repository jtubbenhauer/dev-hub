{
  "name": "dev-hub",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "NODE_ENV=production next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && pnpm --filter @devhub/shared typecheck && pnpm --filter @devhub/agent typecheck",
    "agent:dev": "pnpm --filter @devhub/agent dev",
    "agent:start": "pnpm --filter @devhub/agent start",
    "agent:typecheck": "pnpm --filter @devhub/agent typecheck"
  },
  "dependencies": {
    "@catppuccin/codemirror": "^1.0.3",
